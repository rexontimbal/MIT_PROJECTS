# ============================================================
# LOCAL DEVELOPMENT (.env)
# Copy this file to .env and fill in your local values.
# For Railway deployment, set these as environment variables
# in the Railway project dashboard.
# ============================================================

# Django Core
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- RAILWAY: set DEBUG=False and ALLOWED_HOSTS=yourdomain.up.railway.app ----

# Database (Local PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=accident_hotspot_db
DB_USER=postgres
DB_PASSWORD=IREX9911
DB_HOST=localhost
DB_PORT=5432

# ---- RAILWAY: set DATABASE_URL=postgresql://... (Railway provides this auto) ----
DATABASE_URL=

# CSRF Trusted Origins (add your Railway domain)
# e.g. https://agnes-app.up.railway.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ============================================================
# CLOUDINARY (Free media/photo storage — sign up at cloudinary.com)
# Required for uploaded report photos to persist on Railway
# ============================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mapbox (Optional — free satellite map tiles)
# Get token at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@pnp-caraga.gov.ph

# Celery / Redis (Optional — only needed for background clustering tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
